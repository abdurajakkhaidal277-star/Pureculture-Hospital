{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the system (patient, doctor, or admin).",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "role": { "type": "string", "enum": ["patient", "doctor", "admin"], "description": "User role" },
        "phone": { "type": "string", "description": "Phone number" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation date" },
        "specialization": { "type": "string", "description": "Doctor's specialization (if role is doctor)" },
        "schedule": { "type": "string", "description": "Doctor's schedule (if role is doctor)" },
        "address": { "type": "string", "description": "Patient's address (if role is patient)" },
        "birthdate": { "type": "string", "format": "date", "description": "Patient's birthdate (if role is patient)" },
        "gender": { "type": "string", "description": "Patient's gender (if role is patient)" }
      },
      "required": ["name", "email", "role"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "An appointment between a patient and a doctor.",
      "type": "object",
      "properties": {
        "patientId": { "type": "string", "description": "UID of the patient" },
        "doctorId": { "type": "string", "description": "UID of the doctor" },
        "patientName": { "type": "string", "description": "Name of the patient" },
        "doctorName": { "type": "string", "description": "Name of the doctor" },
        "date": { "type": "string", "format": "date-time", "description": "Appointment date and time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"], "description": "Appointment status" },
        "notes": { "type": "string", "description": "Consultation notes" }
      },
      "required": ["patientId", "doctorId", "date", "status"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "An invoice for an appointment.",
      "type": "object",
      "properties": {
        "appointmentId": { "type": "string", "description": "ID of the appointment" },
        "patientId": { "type": "string", "description": "UID of the patient" },
        "totalAmount": { "type": "number", "description": "Total amount to pay" },
        "status": { "type": "string", "enum": ["unpaid", "paid"], "description": "Payment status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Invoice creation date" }
      },
      "required": ["appointmentId", "patientId", "totalAmount", "status"]
    },
    "Payment": {
      "title": "Payment",
      "description": "A payment record for an invoice.",
      "type": "object",
      "properties": {
        "invoiceId": { "type": "string", "description": "ID of the invoice" },
        "method": { "type": "string", "description": "Payment method (e.g., GCash, Maya)" },
        "amount": { "type": "number", "description": "Amount paid" },
        "status": { "type": "string", "description": "Payment status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Payment date" }
      },
      "required": ["invoiceId", "method", "amount", "status"]
    },
    "Prescription": {
      "title": "Prescription",
      "description": "A prescription issued during an appointment.",
      "type": "object",
      "properties": {
        "appointmentId": { "type": "string", "description": "ID of the appointment" },
        "patientId": { "type": "string", "description": "UID of the patient" },
        "doctorId": { "type": "string", "description": "UID of the doctor" },
        "details": { "type": "string", "description": "Prescription details" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Prescription date" }
      },
      "required": ["appointmentId", "patientId", "doctorId", "details"]
    },
    "LabResult": {
      "title": "LabResult",
      "description": "A lab result for a patient.",
      "type": "object",
      "properties": {
        "patientId": { "type": "string", "description": "UID of the patient" },
        "result": { "type": "string", "description": "Lab result details" },
        "fileUrl": { "type": "string", "description": "URL to the lab result file" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Lab result date" }
      },
      "required": ["patientId", "result"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/appointments/{appointmentId}": { "schema": "Appointment", "description": "Appointments" },
    "/invoices/{invoiceId}": { "schema": "Invoice", "description": "Invoices" },
    "/payments/{paymentId}": { "schema": "Payment", "description": "Payments" },
    "/prescriptions/{prescriptionId}": { "schema": "Prescription", "description": "Prescriptions" },
    "/lab_results/{resultId}": { "schema": "LabResult", "description": "Lab results" }
  }
}
